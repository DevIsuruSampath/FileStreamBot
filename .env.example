# -----------------------------
# Mandatory
# -----------------------------
API_ID=123456
API_HASH=your_api_hash
BOT_TOKEN=123456:your_bot_token
OWNER_ID=123456789
FLOG_CHANNEL=-1001234567890
ULOG_CHANNEL=-1001234567890
DATABASE_URL=mongodb://user:pass@host:27017

# Public bot URL/domain (without http/https)
FQDN=example.com

# -----------------------------
# Recommended
# -----------------------------
WORKERS=6
PORT=8080
BIND_ADDRESS=0.0.0.0
HAS_SSL=False
NO_PORT=False
SLEEP_THRESHOLD=60
SESSION_NAME=FileStream

# Force-subscribe options
UPDATES_CHANNEL=your_updates_channel_username
FORCE_SUB_ID=-1001234567890
FORCE_SUB=False
# Backward compatibility key (older deployments)
FORCE_UPDATES_CHANNEL=False

# Optional media
FILE_PIC=https://graph.org/file/5bb9935be0229adf98b73.jpg
START_PIC=https://graph.org/file/290af25276fa34fa8f0aa.jpg
VERIFY_PIC=https://graph.org/file/736e21cc0efa4d8c2a0e4.jpg

# Optional access control
AUTH_USERS=
MODE=primary

# Optional URL shortener
# Supports dynamic host via env (recommended):
# - urlshortener.devisuru.ggff.net
# - api.urlshortener.devisuru.ggff.net
# - api.gplinks.com
URL_SHORTENER_SITE=
URL_SHORTENER_API_KEY=
# Request timeout in seconds for shortener API calls (default: 5)
URL_SHORTENER_TIMEOUT=5
# Failures before temporary cooldown (default: 2)
URL_SHORTENER_FAIL_THRESHOLD=2
# Cooldown duration in seconds after repeated failures (default: 300)
URL_SHORTENER_COOLDOWN=300

# Optional Adsterra Publisher integration
# Enable ads on web pages (respects /ads ON/OFF status in bot)
ADSTERRA_ENABLE=False
# Smartlink / Direct Link from Adsterra
ADSTERRA_DIRECT_LINK=
# Comma-separated script URLs from Adsterra dashboard
ADSTERRA_SCRIPT_URLS=
# Optional: custom API placeholders
ADSTERRA_PUBLISHER_API_URL=
ADSTERRA_PUBLISHER_API_KEY=

# Optional multi-client bot tokens
# MULTI_TOKEN1=
# MULTI_TOKEN2=
