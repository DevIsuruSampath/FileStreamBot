# -----------------------------
# Mandatory
# -----------------------------
API_ID=123456
API_HASH=your_api_hash
BOT_TOKEN=123456:your_bot_token
OWNER_ID=123456789
FLOG_CHANNEL=-1001234567890
ADMIN_FLOG_CHANNEL=
ULOG_CHANNEL=-1001234567890
DATABASE_URL=mongodb://user:pass@host:27017

# Public bot URL/domain (without http/https)
FQDN=example.com

# -----------------------------
# Recommended
# -----------------------------
WORKERS=6
PORT=8080
BIND_ADDRESS=0.0.0.0
HAS_SSL=False
NO_PORT=False
SLEEP_THRESHOLD=60
# Telegram upload.GetFile supports up to 1 MB per request. Higher values are clamped to 1.
STREAM_CHUNK_SIZE_MB=1
STREAM_PREFETCH_CHUNKS=4
STREAM_LOCAL_CACHE_ENABLED=True
STREAM_CACHE_DIR=/tmp/filestream_stream_cache
STREAM_CACHE_MAX_GB=10
STREAM_CACHE_TTL_HOURS=24
SESSION_NAME=FileStream

# Force-subscribe options
UPDATES_CHANNEL=your_updates_channel_username
FORCE_SUB_ID=-1001234567890
FORCE_SUB=False
# Backward compatibility key (older deployments)
FORCE_UPDATES_CHANNEL=False

# Optional media
# Accepts an HTTP URL, a Telegram file_id, or a local file path like images/start.png
FILE_PIC=https://graph.org/file/5bb9935be0229adf98b73.jpg
START_PIC=images/start.jpg
LEGAL_PIC=images/start.jpg
VERIFY_PIC=https://graph.org/file/736e21cc0efa4d8c2a0e4.jpg

# Optional access control
AUTH_USERS=
MODE=primary

# Optional URL shortener
# Supports dynamic host via env (recommended):
# - urlshortener.devisuru.ggff.net
# - api.urlshortener.devisuru.ggff.net
# - api.gplinks.com
URL_SHORTENER_SITE=
URL_SHORTENER_API_KEY=
# Request timeout in seconds for shortener API calls (default: 5)
URL_SHORTENER_TIMEOUT=5
# Failures before temporary cooldown (default: 2)
URL_SHORTENER_FAIL_THRESHOLD=2
# Cooldown duration in seconds after repeated failures (default: 300)
URL_SHORTENER_COOLDOWN=300

# Web ads shown in web templates.
# Leave defaults to preserve current behavior, or override per placement.
# Set to False to disable all web ads/social bars globally.
WEB_ADS_ENABLED=True

# Desktop top banner (default keeps existing 728x90 slot)
WEB_ADS_DESKTOP_TOP_BANNER_KEY=9626363529c248162c9238de39d16745
WEB_ADS_DESKTOP_TOP_BANNER_INVOKE_URL=https://www.highperformanceformat.com/9626363529c248162c9238de39d16745/invoke.js
WEB_ADS_DESKTOP_TOP_BANNER_WIDTH=728
WEB_ADS_DESKTOP_TOP_BANNER_HEIGHT=90

# Desktop inline banner (default keeps existing 300x250 slot)
WEB_ADS_DESKTOP_INLINE_BANNER_KEY=49d82824df1bb87901c1aeb13d4a5185
WEB_ADS_DESKTOP_INLINE_BANNER_INVOKE_URL=https://www.highperformanceformat.com/49d82824df1bb87901c1aeb13d4a5185/invoke.js
WEB_ADS_DESKTOP_INLINE_BANNER_WIDTH=300
WEB_ADS_DESKTOP_INLINE_BANNER_HEIGHT=250

# Mobile top banner (default keeps existing 320x50 slot)
WEB_ADS_MOBILE_TOP_BANNER_KEY=92fbe91aad2179437131dbabf96fc28c
WEB_ADS_MOBILE_TOP_BANNER_INVOKE_URL=https://www.highperformanceformat.com/92fbe91aad2179437131dbabf96fc28c/invoke.js
WEB_ADS_MOBILE_TOP_BANNER_WIDTH=320
WEB_ADS_MOBILE_TOP_BANNER_HEIGHT=50

# Mobile bottom banner (default keeps existing 300x250 slot)
WEB_ADS_MOBILE_BOTTOM_BANNER_KEY=49d82824df1bb87901c1aeb13d4a5185
WEB_ADS_MOBILE_BOTTOM_BANNER_INVOKE_URL=https://www.highperformanceformat.com/49d82824df1bb87901c1aeb13d4a5185/invoke.js
WEB_ADS_MOBILE_BOTTOM_BANNER_WIDTH=300
WEB_ADS_MOBILE_BOTTOM_BANNER_HEIGHT=250

# Social bar scripts. Leave blank to disable per device.
WEB_ADS_DESKTOP_SOCIAL_BAR_URL=https://cardinaltangible.com/27/fa/cf/27facf136dc45ce0b5faf7b999e9e6f0.js
WEB_ADS_MOBILE_SOCIAL_BAR_URL=https://cardinaltangible.com/27/fa/cf/27facf136dc45ce0b5faf7b999e9e6f0.js

# Smartlink/click-through URL used by the ad gate. Leave blank to disable it.
WEB_ADS_SMARTLINK_URL=https://cardinaltangible.com/jpxjm6h69?key=654ea398985fb67f67bc8d74aecdedcf

# Optional multi-client bot tokens.
# Each MULTI_TOKEN bot will start, receive updates, reply to users,
# and also participate in streaming/load-balancing.
# Keep numbering sequentially: MULTI_TOKEN1, MULTI_TOKEN2, MULTI_TOKEN3...
# MULTI_TOKEN1=
# MULTI_TOKEN2=
